@model IEnumerable<MeetingRoomBookingSystem.Models.Room>
@{
    ViewData["Title"] = "Meeting Rooms";
    var roomIcons = new[] { "bi-building", "bi-display", "bi-laptop", "bi-mic", "bi-camera-video", "bi-projector" };
    var gradients = new[] {
        "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
        "linear-gradient(135deg, #f093fb 0%, #f5576c 100%)",
        "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)",
        "linear-gradient(135deg, #43e97b 0%, #38f9d7 100%)",
        "linear-gradient(135deg, #fa709a 0%, #fee140 100%)",
        "linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%)"
    };
    int idx = 0;
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-door-open-fill text-primary"></i> Meeting Rooms</h2>
        <p class="text-muted mb-0">Browse and book available spaces</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="bi bi-plus-circle"></i> Add New Room
        </a>
    }
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        var gradient = gradients[idx % gradients.Length];
        var icon = roomIcons[idx % roomIcons.Length];
        idx++;
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 overflow-hidden" style="border-radius: 20px;">
                <div class="position-relative" style="background: @gradient; padding: 2.5rem 1.5rem 1.5rem;">
                    <div class="position-absolute top-0 end-0 mt-3 me-3 opacity-25" style="font-size: 4rem;">
                        <i class="bi @icon text-white"></i>
                    </div>
                    <h4 class="text-white fw-bold mb-0">@item.RoomName</h4>
                </div>
                <div class="card-body d-flex flex-column p-4">
                    <div class="d-flex gap-3 mb-4">
                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3" style="background: var(--mrbs-bg);">
                            <i class="bi bi-people-fill text-primary"></i>
                            <div>
                                <div class="small text-muted fw-medium">Capacity</div>
                                <div class="fw-bold">@item.Capacity people</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-3" style="background: var(--mrbs-bg);">
                            <i class="bi bi-geo-alt-fill text-danger"></i>
                            <div>
                                <div class="small text-muted fw-medium">Location</div>
                                <div class="fw-bold">@item.Location</div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-auto d-flex gap-2">
                        <a asp-controller="Booking" asp-action="Create" asp-route-roomId="@item.RoomId"
                           class="btn btn-primary flex-grow-1 rounded-pill shadow-sm">
                            <i class="bi bi-calendar-plus"></i> Book Now
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.RoomId" class="btn btn-outline-info rounded-pill px-3" title="Edit Room">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.RoomId" method="post"
                                  onsubmit="return confirm('Are you sure you want to delete this room?');">
                                <button type="submit" class="btn btn-outline-danger rounded-pill px-3" title="Delete Room">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 mt-4">
        <div style="font-size: 5rem; opacity: 0.15;"><i class="bi bi-building-slash"></i></div>
        <h4 class="text-muted mt-3">No rooms available yet</h4>
        <p class="text-muted">Rooms will appear here once an admin creates them.</p>
    </div>
}
