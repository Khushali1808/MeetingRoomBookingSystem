@model MeetingRoomBookingSystem.Models.Room

@{
    ViewData["Title"] = "Add Room";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card mt-4 shadow-sm border-success">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0">Add New Meeting Room</h3>
            </div>

            <div class="card-body">

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="RoomName" class="form-label fw-bold"></label>
                        <input asp-for="RoomName" class="form-control" placeholder="Conference Room A" />
                        <span asp-validation-for="RoomName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-bold"></label>
                        <input asp-for="Capacity" class="form-control" type="number" min="1" max="100" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-bold"></label>
                        <input asp-for="Location" class="form-control" placeholder="2nd Floor" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Back</a>
                        <button type="submit" class="btn btn-success">Save Room</button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}