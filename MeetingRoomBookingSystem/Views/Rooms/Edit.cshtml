@model MeetingRoomBookingSystem.Models.Room

@{
    ViewData["Title"] = "Edit Room";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card mt-4 shadow-sm border-info" style="border-radius: 15px;">
            <div class="card-header bg-info text-white" style="border-radius: 15px 15px 0 0;">
                <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> Edit Meeting Room</h3>
            </div>

            <div class="card-body p-4">

                <form asp-action="Edit" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="RoomId" />

                    <div class="mb-3">
                        <label asp-for="RoomName" class="form-label fw-bold"></label>
                        <input asp-for="RoomName" class="form-control rounded-3" />
                        <span asp-validation-for="RoomName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-bold"></label>
                        <input asp-for="Capacity" class="form-control rounded-3" type="number" min="1" max="100" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-bold"></label>
                        <input asp-for="Location" class="form-control rounded-3" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Back to Rooms</a>
                        <button type="submit" class="btn btn-info text-white fw-bold rounded-pill px-4 shadow-sm">Save Changes</button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
